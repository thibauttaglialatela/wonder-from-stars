{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - {{ image[0].title }}{% endblock %}

{% block body %}
    <div class="md:block md:w-2/3 mx-auto my-8">
        <div
                class="block rounded-lg bg-neutral-50 shadow-[0_2px_15px_-3px_rgba(0,0,0,0.07),0_10px_20px_-2px_rgba(0,0,0,0.04)] dark:bg-neutral-700">

            <img
                    class="rounded-t-lg w-full"
                    src="{{ image[0].hdurl }}"
                    alt="{{ image[0].title }}"/>

            <div class="p-6">
                <h1
                        class="mb-2 text-xl font-medium leading-tight text-neutral-800 dark:text-neutral-50">
                    {{ image[0].title }}
                </h1>
                <p class="mb-4 text-base text-neutral-600 dark:text-neutral-200">
                    {{ image[0].explanation }}
                </p>
                <div
                        class="flex justify-around gap-1.5"
                        role="group">
                    {{ component('Button:Link', {
                        href: path('app_carousel'),
                        buttonText: 'Back'
                    }) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
